# Normalize text files in git and enforce LF in working tree.
* text=auto

# Enforce LF for source, docs, and config files across all OSes.
*.cpp text eol=lf
*.h text eol=lf
*.ino text eol=lf
*.md text eol=lf
*.properties text eol=lf
*.txt text eol=lf
Doxyfile text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.html text eol=lf
*.css text eol=lf
*.js text eol=lf

# Denote all files that are truly binary and should not be modified.
*.png binary
*.jpg binary
*.gif binary
*.ico binary
*.pdf binary
